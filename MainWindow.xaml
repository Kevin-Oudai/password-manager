<Window x:Class="PasswordManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:PasswordManager.Models"
        mc:Ignorable="d"
        Title="Password Manager"
        Width="1520"
        Height="930"
        MinWidth="1280"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        PreviewMouseDown="HandleMouseInteraction"
        PreviewKeyDown="HandleKeyboardInteraction">
    <Window.DataContext>
        <Binding RelativeSource="{RelativeSource Self}" />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Color x:Key="AppBackground">#FFF4F6FB</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="BorderColor">#FFD8E3F0</Color>
        <Color x:Key="TextColor">#FF132238</Color>
        <Color x:Key="MutedTextColor">#FF5F728A</Color>
        <Color x:Key="AccentColor">#FF0F6FFF</Color>
        <Color x:Key="AccentDarkColor">#FF0A55C6</Color>
        <Color x:Key="AccentSoftColor">#FFE5F0FF</Color>
        <Color x:Key="DangerColor">#FFD64045</Color>
        <Color x:Key="ShadowColor">#220C1A2A</Color>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

        <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFFFFFFF" />
            <GradientStop Offset="0.45" Color="#FFF4F8FF" />
            <GradientStop Offset="1" Color="#FFEAF4FF" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="CardShadowEffect"
                          Color="#14000000"
                          BlurRadius="30"
                          ShadowDepth="10"
                          Direction="270"
                          Opacity="0.4" />

        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect" Value="{StaticResource CardShadowEffect}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style TargetType="Button" x:Key="AccentButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFF2F2" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#FFFFD4D4" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Fill="#FFE9F3FF" Canvas.Left="-120" Canvas.Top="-140" />
            <Ellipse Width="340" Height="340" Fill="#FFF7EFE6" Canvas.Right="-80" Canvas.Top="80" />
            <Ellipse Width="300" Height="300" Fill="#FFE8FFF5" Canvas.Left="1040" Canvas.Top="620" />
        </Canvas>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Background="{StaticResource HeroGradientBrush}"
                    Padding="26"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="78"
                                Height="78"
                                CornerRadius="26"
                                Background="#F6FFFFFF"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,0,18,0">
                            <Image Source="Assets/vault-logo.png" Stretch="Uniform" />
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="30" FontWeight="Bold" Text="Password Vault" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="15"
                                       Text="Local-only encrypted storage for passwords and payment cards. Unlocks with one master password, auto-locks after inactivity, and stays one click away in the system tray." />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#CCFFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18,14"
                            MinWidth="250">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Session" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource AccentDarkBrush}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Text="{Binding SessionStatus}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding VaultLocationLabel}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Text="{Binding LogLocationLabel}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="520" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,18,0">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="Bold" Text="Overview" />
                                <TextBlock Margin="0,6,0,18"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Single-user vault for passwords and payment cards with local storage, CSV import/export, and encrypted backups." />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{StaticResource AccentSoftBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="16"
                                            Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Entries" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Text="{Binding EntryCount}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Background="#FFF4F9F4"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="16"
                                            Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Favorites" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Text="{Binding FavoriteCount}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Background="#FFF9FBFE"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Vault policy" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="Launch always requires the master password. Clipboard copies clear after 30 seconds. The vault locks after 15 minutes of inactivity, Windows lock, or sleep." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="Bold" Text="Quick Generator" />
                                <TextBlock Margin="0,6,0,16"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="Generate a strong password for login entries, copy it, or inject it into the editor." />

                                <TextBlock FontWeight="SemiBold" Text="Length" />
                                <TextBox Text="{Binding GeneratorLength, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Content="Uppercase (A-Z)"
                                          IsChecked="{Binding IncludeUppercase, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Lowercase (a-z)"
                                          IsChecked="{Binding IncludeLowercase, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Numbers (0-9)"
                                          IsChecked="{Binding IncludeNumbers, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Symbols (!@$...)"
                                          IsChecked="{Binding IncludeSymbols, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Exclude ambiguous characters"
                                          IsChecked="{Binding ExcludeAmbiguousCharacters, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel Margin="0,16,0,8">
                                    <Button Style="{StaticResource AccentButtonStyle}" Content="Generate" Click="GeneratePassword_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Copy" Click="CopyGeneratedPassword_Click" />
                                </WrapPanel>

                                <TextBlock FontWeight="SemiBold" Text="Generated password" />
                                <TextBox Text="{Binding GeneratedPassword}"
                                         IsReadOnly="True"
                                         FontSize="16"
                                         FontFamily="Consolas"
                                         Background="#FFF7FAFF"
                                         MinHeight="86"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock FontSize="20" FontWeight="Bold" Text="Entries" />
                            <TextBlock Margin="0,6,0,16"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Search, sort, and manage saved passwords and payment cards." />

                            <WrapPanel Margin="0,0,0,10">
                                <Button Style="{StaticResource AccentButtonStyle}" Content="Add Login" Click="AddPasswordEntry_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Add Card" Click="AddCardEntry_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Import CSV" Click="ImportCsv_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Export CSV" Click="ExportCsv_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Backup" Click="ExportBackup_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Restore Backup" Click="RestoreBackup_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Lock" Click="LockVault_Click" />
                            </WrapPanel>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Margin="0,0,12,0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <ComboBox Grid.Column="1"
                                      SelectedValue="{Binding SortMode, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Content"
                                      SelectionChanged="SortMode_SelectionChanged">
                                <ComboBoxItem Content="Recently Updated" IsSelected="True" />
                                <ComboBoxItem Content="Title A-Z" />
                                <ComboBoxItem Content="Favorites First" />
                            </ComboBox>
                        </Grid>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding EntriesView}"
                                     SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:VaultEntry}">
                                        <Border Background="#FFF9FBFE"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="20"
                                                Padding="18">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{Binding Subtitle}" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="{Binding Url}" />
                                                    <TextBlock Margin="0,10,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12"
                                                               Text="{Binding ModifiedLabel}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top">
                                                    <Border Background="{StaticResource AccentSoftBrush}"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Padding="10,4"
                                                            Margin="0,0,0,8">
                                                        <TextBlock FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding TypeLabel}" />
                                                    </Border>

                                                    <TextBlock FontSize="20"
                                                               Foreground="#FFF5B700"
                                                               Text="*">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid Visibility="{Binding HasSelectionAndNotEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock FontSize="20" FontWeight="Bold" Text="Entry Details" />
                                    <TextBlock Margin="0,6,0,16"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Reveal or copy sensitive details only when needed, then let the clipboard clear itself automatically." />

                                    <WrapPanel Margin="0,0,0,10">
                                        <Button Style="{StaticResource AccentButtonStyle}" Content="Edit" Click="EditEntry_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Copy Username"
                                                Click="CopySelectedUsername_Click"
                                                Visibility="{Binding SelectedEntry.IsPasswordEntry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Copy Password"
                                                Click="CopySelectedPassword_Click"
                                                Visibility="{Binding SelectedEntry.IsPasswordEntry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Copy Card Number"
                                                Click="CopySelectedCardNumber_Click"
                                                Visibility="{Binding SelectedEntry.IsCardEntry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Copy Security Code"
                                                Click="CopySelectedCardSecurityCode_Click"
                                                Visibility="{Binding SelectedEntry.IsCardEntry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Copy PIN"
                                                Click="CopySelectedCardPin_Click"
                                                Visibility="{Binding SelectedEntry.IsCardEntry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{Binding SelectedSensitiveToggleLabel}"
                                                Click="ToggleSensitiveVisibility_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="{Binding FavoriteActionLabel}" Click="ToggleFavorite_Click" />
                                        <Button Style="{StaticResource DangerButtonStyle}" Content="Delete" Click="DeleteEntry_Click" />
                                    </WrapPanel>

                                    <Border Background="#FFF9FBFE"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18"
                                            Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Title" />
                                            <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Text="{Binding SelectedEntry.Title}" />
                                            <Border Background="{StaticResource AccentSoftBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    Margin="0,12,0,0"
                                                    HorizontalAlignment="Left">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SelectedEntry.TypeLabel}" />
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Visibility="{Binding SelectedEntry.IsPasswordEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Website or app" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectedEntry.Platform}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="8,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Username or email" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectedEntry.UserName}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Background="#FFF9FBFE"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="18"
                                                Margin="0,0,0,16">
                                            <StackPanel>
                                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Password" />
                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Consolas"
                                                           Text="{Binding SelectedPasswordDisplay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding SelectedEntry.IsCardEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Bank or issuer" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectedEntry.Platform}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="8,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Cardholder name" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectedEntry.CardholderName}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Card number" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Consolas"
                                                               Text="{Binding SelectedCardNumberDisplay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="8,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Expiration" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding SelectedEntry.CardExpiration}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="0,0,8,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Security code" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Consolas"
                                                               Text="{Binding SelectedCardSecurityCodeDisplay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Background="#FFF9FBFE"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="18"
                                                    Margin="8,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="PIN" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Consolas"
                                                               Text="{Binding SelectedCardPinDisplay}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <Border Background="#FFF9FBFE"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18"
                                            Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="URL or portal" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="16"
                                                       Text="{Binding SelectedEntry.Url}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF9FBFE"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Notes" />
                                            <TextBox Margin="0,8,0,0"
                                                     Text="{Binding SelectedEntry.Notes}"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     Background="#FFF9FBFE"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     MinHeight="140" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid Visibility="{Binding IsEditingEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding EditorHeading}" />
                                    <TextBlock Margin="0,6,0,16"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding EditorSubheading}" />

                                    <TextBlock FontWeight="SemiBold" Text="Entry type" />
                                    <ComboBox SelectedValue="{Binding EditorEntry.EntryType, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="{x:Static models:VaultEntryType.Password}" Content="Password" />
                                        <ComboBoxItem Tag="{x:Static models:VaultEntryType.Card}" Content="Card" />
                                    </ComboBox>

                                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Title" />
                                    <TextBox Text="{Binding EditorEntry.Title, UpdateSourceTrigger=PropertyChanged}" />

                                    <StackPanel Visibility="{Binding EditorEntry.IsPasswordEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Website or app" />
                                        <TextBox Text="{Binding EditorEntry.Platform, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="URL" />
                                        <TextBox Text="{Binding EditorEntry.Url, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Username or email" />
                                        <TextBox Text="{Binding EditorEntry.UserName, UpdateSourceTrigger=PropertyChanged}" />

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontWeight="SemiBold" Text="Password" />
                                                <TextBox Text="{Binding EditorEntry.Password, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="Consolas" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,0,0">
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,28,0,8"
                                                        Padding="14,9"
                                                        Content="Use Generated"
                                                        Click="UseGeneratedPassword_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding EditorEntry.IsCardEntry, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Bank or issuer" />
                                        <TextBox Text="{Binding EditorEntry.Platform, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Issuer URL or portal" />
                                        <TextBox Text="{Binding EditorEntry.Url, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Cardholder name" />
                                        <TextBox Text="{Binding EditorEntry.CardholderName, UpdateSourceTrigger=PropertyChanged}" />

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontWeight="SemiBold" Text="Card number" />
                                                <TextBox Text="{Binding EditorEntry.CardNumber, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="Consolas" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock FontWeight="SemiBold" Text="Expiration (MM/YY)" />
                                                <TextBox Text="{Binding EditorEntry.CardExpiration, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontWeight="SemiBold" Text="Security code" />
                                                <TextBox Text="{Binding EditorEntry.CardSecurityCode, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="Consolas" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock FontWeight="SemiBold" Text="PIN (optional)" />
                                                <TextBox Text="{Binding EditorEntry.CardPin, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="Consolas" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <CheckBox IsChecked="{Binding EditorEntry.IsFavorite, UpdateSourceTrigger=PropertyChanged}"
                                              Content="Mark as favorite" />

                                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Notes" />
                                    <TextBox Text="{Binding EditorEntry.Notes, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             Height="150"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap" />

                                    <WrapPanel Margin="0,18,0,0">
                                        <Button Style="{StaticResource AccentButtonStyle}" Content="Save Entry" Click="SaveEntry_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Click="CancelEdit_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid Visibility="{Binding HasNoSelectionAndNotEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Background="#FFF8FBFF"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="26"
                                    VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock FontSize="24" FontWeight="Bold" Text="Select an entry" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="15"
                                               Text="Choose an existing password or card from the list, or add a new one to start building your vault. The quick generator on the left can fill password entries into the editor." />
                                    <WrapPanel Margin="0,18,0,0">
                                        <Button Style="{StaticResource AccentButtonStyle}" Content="Add Login" Click="AddPasswordEntry_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Add Card" Click="AddCardEntry_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Generate Password" Click="GeneratePassword_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>

            <Border Grid.Row="2"
                    Background="#E8FFFFFF"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18,14"
                    Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="{Binding StatusMessage}" />
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Everything stays local on this PC." />
                </Grid>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#CC0F1A28">
            <Border Width="500"
                    Padding="34"
                    CornerRadius="28"
                    Background="White"
                    BorderBrush="#FFD6E1EE"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid Visibility="{Binding ShowCreateVault, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding LockHeading}" />
                            <TextBlock Margin="0,8,0,22"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding LockMessage}" />

                            <TextBlock FontWeight="SemiBold" Text="Master password" />
                            <PasswordBox x:Name="CreatePasswordBox" />

                            <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Confirm password" />
                            <PasswordBox x:Name="ConfirmPasswordBox" />

                            <Border Background="#FFF8FBFF"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="16"
                                    Margin="0,18,0,18">
                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="No recovery is stored. If you forget the master password, the safe path is restoring from an exported encrypted backup." />
                            </Border>

                            <WrapPanel>
                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Content="Create Vault"
                                        Click="CreateVault_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Restore Backup"
                                        Click="RestoreBackup_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Visibility="{Binding ShowUnlockVault, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding LockHeading}" />
                            <TextBlock Margin="0,8,0,22"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding LockMessage}" />

                            <TextBlock FontWeight="SemiBold" Text="Master password" />
                            <PasswordBox x:Name="UnlockPasswordBox" KeyDown="UnlockPasswordBox_KeyDown" />

                            <WrapPanel Margin="0,20,0,0">
                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Content="Unlock Vault"
                                        Click="UnlockVault_Click" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Restore Backup"
                                        Click="RestoreBackup_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
