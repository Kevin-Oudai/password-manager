<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>Assets\vault-logo.ico</ApplicationIcon>
    <Version>1.0.0</Version>
    <Authors>Kevin Oudai</Authors>
    <Product>Password Vault</Product>
    <AssemblyTitle>Password Vault</AssemblyTitle>
    <Description>Local-only encrypted password and card manager for Windows.</Description>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\vault-logo.ico" />
    <Resource Include="Assets\vault-logo.png" />
  </ItemGroup>

</Project>
